# 复制为 .env.local 后按本机修改：
#   copy .env.example .env.local
#
# 服务端专用：Pool SSR、以及 next.config rewrites 上游
TRADE_HUB_API_URL=http://127.0.0.1:8080

# 浏览器 axios baseURL（默认 /hub，走 Next 反向代理，免 CORS）
# NEXT_PUBLIC_TRADE_HUB_BASE_URL=/hub

# 浏览器 WebSocket（行情直连 trade-hub；今日不走 /hub 代理）
# NEXT_PUBLIC_TRADE_HUB_WS_URL=ws://127.0.0.1:8080/ws/ticker

# 可选（已有代码在用，浏览器可读）
# NEXT_PUBLIC_SOLANA_RPC_URL=
# NEXT_PUBLIC_JUPITER_API_URL=
